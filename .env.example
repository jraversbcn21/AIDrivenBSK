# Which logical environment. One of: prod | des | local
ENVIRONMENT=des
# Base URL for the target environment. No trailing path beyond locale root.
BASE_URL=https://des-ecombknj-test-webecom.bk.apps.axdesecocp1.ecommerce.inditex.grp/es/
# Test account credentials (never commit real values)
BERSHKA_USER=
BERSHKA_PASS=

# --- Explorer Agent (all optional) ---
# Classifier mode: rules (default, offline) | llm | auto
EXPLORER_MODE=rules
# Extraction backbone: aria (default; pierces bds- shadow DOM) | dom (light-DOM linkedom path)
EXPLORER_EXTRACTION=aria
# Crawl bounds. Note: the PLP-grid settle wait (M6) adds ~3.5-5s/page — a full
# 80-page/session crawl needs EXPLORER_TIME_BUDGET_MS=1200000 (20 min) to finish
# with margin; the default below is comfortable only for small/bounded crawls.
EXPLORER_MAX_PAGES=200
EXPLORER_TIME_BUDGET_MS=600000
# Explorer refuses to crawl prod unless this is explicitly set
EXPLORER_ALLOW_PROD=false
# Interaction discovery (M8): open non-destructive overlays/dialogs during the crawl (aria mode only).
# EXPLORER_INTERACTIONS=on|off (default on) ; EXPLORER_MAX_INTERACTIONS_PER_PAGE (default 3)
# Only needed for EXPLORER_MODE=llm|auto
ANTHROPIC_API_KEY=
